# =============================================================================
# QUANTSTREAM ANALYTICS PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# TASK MASTER AI API KEYS (For Project Management)
# -----------------------------------------------------------------------------
# API Keys (Required to enable respective provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI models. Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional, for Mistral AI models.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional, for xAI AI models.
GROQ_API_KEY="YOUR_GROQ_KEY_HERE"                     # Optional, for Groq models.
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"         # Optional, for OpenRouter models.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional, for Azure OpenAI models (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require authentication.
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub import/export features. Format: ghp_... or github_pat_...

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
ENVIRONMENT="development"
DEBUG="true"
LOG_LEVEL="INFO"
SECRET_KEY="your-secret-key-change-in-production"

# Application URLs
API_BASE_URL="http://localhost:8000"
DASHBOARD_URL="http://localhost:8501"
MLFLOW_TRACKING_URI="http://localhost:5000"

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# PostgreSQL Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quantstream"
DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_NAME="quantstream"
DATABASE_USER="postgres"
DATABASE_PASSWORD="postgres"

# MLflow Database
MLFLOW_BACKEND_STORE_URI="postgresql://postgres:postgres@localhost:5432/mlflow"

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_DB="0"
REDIS_PASSWORD=""

# -----------------------------------------------------------------------------
# KAFKA CONFIGURATION
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS="localhost:29092"
KAFKA_CLIENT_ID="quantstream-client"
KAFKA_GROUP_ID="quantstream-group"
KAFKA_AUTO_OFFSET_RESET="earliest"
KAFKA_ENABLE_AUTO_COMMIT="true"

# Topic Configuration
KAFKA_TOPIC_RAW_DATA="raw-market-data"
KAFKA_TOPIC_PROCESSED_DATA="processed-market-data"
KAFKA_TOPIC_ALERTS="trading-alerts"
KAFKA_TOPIC_METRICS="system-metrics"

# -----------------------------------------------------------------------------
# SPARK CONFIGURATION
# -----------------------------------------------------------------------------
SPARK_MASTER_URL="spark://localhost:7077"
SPARK_APP_NAME="QuantStream Analytics"
SPARK_DRIVER_MEMORY="2g"
SPARK_EXECUTOR_MEMORY="2g"
SPARK_EXECUTOR_CORES="2"

# Delta Lake Configuration
DELTA_LAKE_TABLE_PATH="s3a://quantstream-data/delta-tables"
DELTA_WAREHOUSE_DIR="s3a://quantstream-data/warehouse"

# -----------------------------------------------------------------------------
# MLFLOW CONFIGURATION
# -----------------------------------------------------------------------------
MLFLOW_EXPERIMENT_NAME="quantstream-ml"
MLFLOW_ARTIFACT_ROOT="s3://mlflow-artifacts"
MLFLOW_S3_ENDPOINT_URL="http://localhost:9000"

# -----------------------------------------------------------------------------
# OBJECT STORAGE (MinIO/S3)
# -----------------------------------------------------------------------------
S3_ENDPOINT_URL="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="quantstream-data"
S3_REGION="us-east-1"

# AWS S3 (for production)
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_DEFAULT_REGION="us-east-1"
AWS_S3_BUCKET="quantstream-prod-data"

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
# Prometheus
PROMETHEUS_URL="http://localhost:9090"
PROMETHEUS_METRICS_PORT="8000"
PROMETHEUS_PUSHGATEWAY_URL="http://localhost:9091"

# Grafana
GRAFANA_URL="http://localhost:3000"
GRAFANA_USERNAME="admin"
GRAFANA_PASSWORD="admin"

# OpenTelemetry
OTEL_SERVICE_NAME="quantstream-analytics"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
OTEL_RESOURCE_ATTRIBUTES="service.name=quantstream,service.version=0.1.0"

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# -----------------------------------------------------------------------------
# JWT Configuration
JWT_SECRET_KEY="your-jwt-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_HOURS="24"

# API Rate Limiting
RATE_LIMIT_PER_MINUTE="100"
RATE_LIMIT_BURST="20"

# CORS Configuration
CORS_ORIGINS="http://localhost:3000,http://localhost:8501,http://localhost:8000"
CORS_ALLOW_CREDENTIALS="true"

# -----------------------------------------------------------------------------
# FEATURE STORE CONFIGURATION
# -----------------------------------------------------------------------------
FEATURE_STORE_BACKEND="redis"
FEATURE_STORE_ONLINE_URI="redis://localhost:6379"
FEATURE_STORE_OFFLINE_URI="postgresql://postgres:postgres@localhost:5432/quantstream"

# -----------------------------------------------------------------------------
# DATA PIPELINE CONFIGURATION
# -----------------------------------------------------------------------------
# Batch Processing
BATCH_SIZE="1000"
BATCH_INTERVAL_SECONDS="60"
MAX_RETRIES="3"
RETRY_BACKOFF_FACTOR="2"

# Stream Processing
STREAM_BUFFER_SIZE="10000"
STREAM_TIMEOUT_SECONDS="30"
CHECKPOINT_INTERVAL_SECONDS="60"

# Data Quality
DATA_QUALITY_CHECKS_ENABLED="true"
DATA_QUALITY_THRESHOLD="0.95"
ANOMALY_DETECTION_ENABLED="true"

# -----------------------------------------------------------------------------
# EXTERNAL DATA SOURCES
# -----------------------------------------------------------------------------
# Market Data API
MARKET_DATA_API_KEY="your_market_data_api_key"
MARKET_DATA_BASE_URL="https://api.marketdata.com"
MARKET_DATA_RATE_LIMIT="1000"

# Alternative Data Sources
ALPHA_VANTAGE_API_KEY="your_alpha_vantage_key"
QUANDL_API_KEY="your_quandl_key"
BLOOMBERG_API_KEY="your_bloomberg_key"

# -----------------------------------------------------------------------------
# AIRFLOW CONFIGURATION
# -----------------------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR="LocalExecutor"
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN="postgresql+psycopg2://postgres:postgres@localhost:5432/airflow"
AIRFLOW__CORE__FERNET_KEY="your-fernet-key-here-generate-with-python-cryptography"
AIRFLOW__WEBSERVER__DEFAULT_USER_USERNAME="admin"
AIRFLOW__WEBSERVER__DEFAULT_USER_PASSWORD="admin"
AIRFLOW__WEBSERVER__DEFAULT_USER_EMAIL="admin@quantstream.ai"

# -----------------------------------------------------------------------------
# PERFORMANCE TUNING
# -----------------------------------------------------------------------------
# Database Connection Pool
DB_POOL_SIZE="20"
DB_MAX_OVERFLOW="30"
DB_POOL_TIMEOUT="30"
DB_POOL_RECYCLE="3600"

# Redis Connection Pool
REDIS_POOL_SIZE="20"
REDIS_POOL_TIMEOUT="10"

# Kafka Consumer/Producer
KAFKA_CONSUMER_TIMEOUT_MS="10000"
KAFKA_PRODUCER_TIMEOUT_MS="10000"
KAFKA_FETCH_MAX_WAIT_MS="1000"
KAFKA_MAX_POLL_RECORDS="500"

# -----------------------------------------------------------------------------
# DEVELOPMENT & TESTING
# -----------------------------------------------------------------------------
# Testing Database
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quantstream_test"
TEST_REDIS_URL="redis://localhost:6379/1"

# Development Tools
JUPYTER_ENABLE_LAB="yes"
JUPYTER_TOKEN=""
JUPYTER_PASSWORD=""

# Hot Reloading
UVICORN_RELOAD="true"
STREAMLIT_DEVELOPMENT_MODE="true"